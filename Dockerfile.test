# syntax=docker/dockerfile:1.7
FROM python:3.14-slim AS test

LABEL maintainer="Netresearch DTT GmbH <sebastian.mendel@netresearch.de>" \
      org.opencontainers.image.title="jira-to-openproject-test" \
      org.opencontainers.image.description="Test image for jira-to-openproject" \
      org.opencontainers.image.source="https://github.com/netresearch/jira-to-openproject" \
      org.opencontainers.image.licenses="MIT"

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

WORKDIR /app

# System deps (build tools kept here since tests may compile extensions)
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        curl \
        git \
        libffi-dev \
        libssl-dev \
        openssh-client \
        python3-dev \
        tmux \
    && rm -rf /var/lib/apt/lists/*
# docker.io intentionally omitted - uses SSH-based remote Docker client

# Install uv
RUN curl -LsSf https://astral.sh/uv/install.sh | UV_INSTALL_DIR=/usr/local/bin sh

RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app

# Dependency layer (cached)
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-install-project

# Source layer
COPY --chown=appuser:appuser . .

# Runtime directories
RUN mkdir -p /app/var/logs /app/var/data /app/var/run && \
    chown -R appuser:appuser /app/var

# Install project with dev+test extras
RUN uv pip install --system . && \
    uv pip install --system '.[dev,test]'

USER appuser

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import src; import pytest; import sys; sys.exit(0)" || exit 1

CMD ["sleep", "infinity"]
